{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "c-vita.vercel.app"
        }
      ],
      "destination": "https://www.cvzume.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-transform"
        }
      ]
    }
  ]
}
